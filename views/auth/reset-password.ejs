<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-900 via-<%= color %>-950 to-slate-900 flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <a href="<%= backUrl %>" class="inline-flex items-center gap-2 text-slate-400 hover:text-white text-sm mb-6 transition">← Back to Login</a>
      <div class="w-14 h-14 bg-<%= color %>-500 rounded-2xl flex items-center justify-center text-2xl mx-auto mb-4 shadow-lg"><%= icon %></div>
      <h1 class="text-2xl font-bold text-white">Reset Password</h1>
      <p class="text-slate-400 text-xs mt-1"><%= portalLabel %> Portal</p>
    </div>

    <% if (success) { %>
      <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-8 text-center">
        <div class="w-12 h-12 bg-green-500/20 border border-green-400/30 rounded-full flex items-center justify-center text-green-400 text-2xl mx-auto mb-4">✓</div>
        <h2 class="text-lg font-bold text-white mb-2">Password Reset!</h2>
        <p class="text-slate-400 text-sm mb-6">Your password has been updated successfully.</p>
        <a href="<%= backUrl %>" class="inline-block bg-<%= color %>-600 hover:bg-<%= color %>-500 text-white text-sm font-semibold px-6 py-2.5 rounded-xl transition">Go to Login →</a>
      </div>
    <% } else { %>
      <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-8">
        <% if (error) { %>
          <div class="bg-red-500/20 border border-red-400/30 text-red-300 rounded-xl px-4 py-3 text-sm mb-5"><%= error %></div>
        <% } %>
        <p class="text-slate-400 text-sm mb-5">Enter your registered email and set a new password.</p>
        <form method="POST" action="/api/reset-password">
          <input type="hidden" name="role" value="<%= role %>"/>
          <div class="space-y-4">
            <div>
              <label class="text-xs font-medium text-slate-300 block mb-1.5">Email Address</label>
              <input type="email" name="email" required placeholder="your@email.com" autocomplete="email"
                class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-2.5 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-<%= color %>-400"/>
            </div>
            <div>
              <label class="text-xs font-medium text-slate-300 block mb-1.5">New Password</label>
              <input type="password" name="new_password" id="np" required placeholder="Min 6 characters" minlength="6"
                class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-2.5 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-<%= color %>-400"/>
            </div>
            <div>
              <label class="text-xs font-medium text-slate-300 block mb-1.5">Confirm Password</label>
              <input type="password" name="confirm_password" required placeholder="Repeat password" minlength="6"
                oninput="this.setCustomValidity(this.value !== document.getElementById('np').value ? 'Passwords do not match' : '')"
                class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-2.5 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-<%= color %>-400"/>
            </div>
            <button type="submit" class="w-full bg-<%= color %>-600 hover:bg-<%= color %>-500 text-white font-semibold py-2.5 rounded-xl transition text-sm mt-2">
              Set New Password
            </button>
          </div>
        </form>
      </div>
    <% } %>
  </div>
</body>
</html>
