<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
  <%- include('../partials/sidebar', { currentPage, user }) %>

  <div class="ml-56 min-h-screen">
    <div class="bg-white border-b border-gray-200 px-8 py-4">
      <div class="text-xs text-gray-400 mb-1">Courses › <%= course.course_code %> › Edit</div>
      <h1 class="text-xl font-bold text-gray-800">Edit Course</h1>
      <p class="text-gray-400 text-sm">Manage module details and assign instructional staff</p>
    </div>

    <div class="p-8">
      <% if (error) { %>
        <div class="bg-red-50 text-red-600 px-4 py-3 rounded-lg mb-6 text-sm"><%= error %></div>
      <% } %>

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 max-w-2xl">
        <form method="POST" action="/api/courses/<%= course.id %>/edit">
          <div class="grid grid-cols-2 gap-6">
            <div class="col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Course Name</label>
              <input type="text" name="course_name" value="<%= course.course_name %>" required
                class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"/>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Course Code</label>
              <input type="text" name="course_code" value="<%= course.course_code %>" required
                class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"/>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Department</label>
              <select name="department" required
                class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                <% ['Computer Science & Engineering','Mathematics','Physics','English','Business','History'].forEach(dept => { %>
                  <option <%= course.department === dept ? 'selected' : '' %>><%= dept %></option>
                <% }) %>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Instructor / Teacher</label>
              <input type="text" name="instructor" value="<%= course.instructor ?? '' %>"
                class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"/>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
              <select name="is_active"
                class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option value="true" <%= course.is_active ? 'selected' : '' %>>Active</option>
                <option value="false" <%= !course.is_active ? 'selected' : '' %>>Inactive</option>
              </select>
            </div>
            <div class="col-span-2">
              <label class="block text-sm font-medium text-gray-700 mb-1">Course Description</label>
              <textarea name="description" rows="3"
                class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                <%= course.description ?? '' %>
              </textarea>
            </div>
          </div>

          <div class="flex items-center justify-between mt-8">
            <div class="flex gap-4">
              <button type="submit"
                class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2.5 rounded-lg transition text-sm">
                Update Course
              </button>
              <a href="/api/courses"
                class="border border-gray-200 text-gray-600 font-medium px-6 py-2.5 rounded-lg text-sm hover:bg-gray-50">
                Cancel
              </a>
            </div>
            <form method="POST" action="/api/courses/<%= course.id %>/delete"
              onsubmit="return confirm('Delete this course?')">
              <button type="submit" class="text-red-500 hover:text-red-600 text-sm font-medium">
                Delete Course
              </button>
            </form>
          </div>
        </form>

        <!-- System Note -->
        <div class="mt-6 bg-blue-50 rounded-lg p-4 flex gap-3">
          <span class="text-blue-600">ℹ️</span>
          <div>
            <div class="text-sm font-semibold text-blue-700">System Note</div>
            <div class="text-xs text-blue-600 mt-1">
              Updating this course will affect all currently enrolled students. Ensure course code changes are double-checked as they may affect historical records.
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>

