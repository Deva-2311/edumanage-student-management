<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title>Change Password — EduManage</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-gray-50">
  <!-- Student Sidebar -->
  <div class="fixed left-0 top-0 h-full w-56 bg-white border-r border-gray-200 flex flex-col z-10">
    <div class="px-6 py-5 border-b border-gray-100">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 bg-purple-600 rounded-lg flex items-center justify-center text-white text-sm">🎓</div>
        <div><div class="font-bold text-gray-800 text-sm">EduManage</div><div class="text-xs text-purple-500">Student Portal</div></div>
      </div>
    </div>
    <nav class="flex-1 px-3 py-4 space-y-1">
      <a href="/api/student-portal" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50"><span>📊</span> My Dashboard</a>
      <a href="/api/student-portal/marks" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50"><span>📝</span> My Marks</a>
      <a href="/api/student-portal/attendance" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50"><span>✅</span> My Attendance</a>
      <a href="/api/student-portal/password" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium bg-purple-50 text-purple-600"><span>🔒</span> Change Password</a>
    </nav>
    <div class="px-4 py-4 border-t border-gray-100">
      <div class="text-xs font-semibold text-gray-800"><%= user?.name %></div>
      <div class="text-xs text-purple-400 mb-2">Student</div>
      <a href="/api/logout" class="flex items-center gap-2 text-xs text-red-500 hover:text-red-600"><span>→</span> Logout</a>
    </div>
  </div>

  <div class="ml-56 min-h-screen">
    <div class="bg-white border-b border-gray-200 px-8 py-4">
      <h1 class="text-xl font-bold text-gray-800">Change Password</h1>
      <p class="text-xs text-gray-400 mt-0.5">Update your Student Portal password</p>
    </div>
    <div class="p-8 max-w-lg">
      <% if (success) { %>
        <div class="bg-green-50 border border-green-200 text-green-700 rounded-xl px-4 py-4 text-sm flex items-center gap-3 mb-6">
          <span class="text-lg">✓</span>
          <div><strong>Password updated!</strong> Your new password is now active.</div>
        </div>
      <% } %>
      <% if (error) { %>
        <div class="bg-red-50 border border-red-200 text-red-600 rounded-xl px-4 py-3 text-sm mb-6">✗ <%= error %></div>
      <% } %>

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <form method="POST" action="/api/student-portal/password">
          <div class="space-y-4">
            <div>
              <label class="text-xs text-gray-500 font-medium block mb-1">Current Password</label>
              <input type="password" name="current_password" required autocomplete="current-password"
                class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-purple-400"/>
            </div>
            <div>
              <label class="text-xs text-gray-500 font-medium block mb-1">New Password</label>
              <input type="password" name="new_password" id="np" required minlength="6" autocomplete="new-password"
                class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-purple-400"/>
            </div>
            <div>
              <label class="text-xs text-gray-500 font-medium block mb-1">Confirm New Password</label>
              <input type="password" name="confirm_password" required minlength="6" autocomplete="new-password"
                oninput="this.setCustomValidity(this.value !== document.getElementById('np').value ? 'Passwords do not match' : '')"
                class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-purple-400"/>
            </div>
            <button type="submit"
              class="w-full bg-purple-600 hover:bg-purple-700 text-white text-sm font-semibold py-2.5 rounded-lg transition">
              Update Password
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
