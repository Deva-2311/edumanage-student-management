<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-gray-50">

  <%- include('../partials/sidebar', { currentPage: 'dashboard', user }) %>

  <!-- Main Content -->
  <div class="ml-56 min-h-screen">

    <!-- Top Bar -->
    <div class="bg-white border-b border-gray-200 px-8 py-4 flex items-center justify-between">
      <h1 class="text-xl font-bold text-gray-800">Dashboard Overview</h1>
      <div class="flex items-center gap-4">
        <input type="text" placeholder="Search students, courses..."
          class="border border-gray-200 rounded-lg px-4 py-2 text-sm w-72 focus:outline-none focus:ring-2 focus:ring-blue-500"/>
        <div class="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center text-white text-sm font-bold">
          <%= user?.name?.charAt(0) ?? 'A' %>
        </div>
      </div>
    </div>

    <div class="p-8">

      <!-- Stat Cards -->
      <div class="grid grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="flex items-center justify-between mb-4">
            <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center text-xl">👤</div>
            <span class="text-green-500 text-sm font-semibold">↑ Active</span>
          </div>
          <div class="text-gray-500 text-sm">Total Students</div>
          <div class="text-3xl font-bold text-gray-800 mt-1"><%= totalStudents %></div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="flex items-center justify-between mb-4">
            <div class="w-10 h-10 bg-orange-50 rounded-lg flex items-center justify-center text-xl">📚</div>
            <span class="text-blue-500 text-sm font-semibold">↑ Active</span>
          </div>
          <div class="text-gray-500 text-sm">Total Courses</div>
          <div class="text-3xl font-bold text-gray-800 mt-1"><%= totalCourses %></div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="flex items-center justify-between mb-4">
            <div class="w-10 h-10 bg-green-50 rounded-lg flex items-center justify-center text-xl">✅</div>
            <span class="text-green-500 text-sm font-semibold">↑ <%= attendanceRate %>%</span>
          </div>
          <div class="text-gray-500 text-sm">Attendance Today</div>
          <div class="text-3xl font-bold text-gray-800 mt-1"><%= attendanceRate %>%</div>
        </div>
      </div>

      <!-- Charts Row -->
      <div class="grid grid-cols-2 gap-6 mb-8">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="font-semibold text-gray-800">Enrollment Trends</h2>
              <p class="text-gray-400 text-xs">Student growth over last 6 months</p>
            </div>
            <span class="text-blue-600 font-bold text-lg"><%= totalEnrollments %></span>
          </div>
          <canvas id="enrollmentChart" height="120"></canvas>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="font-semibold text-gray-800">Attendance Overview</h2>
              <p class="text-gray-400 text-xs">Weekly breakdown</p>
            </div>
            <span class="text-blue-600 font-bold text-lg"><%= attendanceRate %>%</span>
          </div>
          <canvas id="attendanceChart" height="120"></canvas>
        </div>
      </div>

      <!-- Recent Activity -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100">
        <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
          <h2 class="font-semibold text-gray-800">Recent Activity</h2>
          <a href="/api/logs" class="text-blue-600 text-sm font-medium hover:underline">View All</a>
        </div>
        <table class="w-full">
          <thead>
            <tr class="text-xs text-gray-400 uppercase border-b border-gray-100">
              <th class="px-6 py-3 text-left">Student</th>
              <th class="px-6 py-3 text-left">Course</th>
              <th class="px-6 py-3 text-left">Status</th>
              <th class="px-6 py-3 text-left">Date</th>
            </tr>
          </thead>
          <tbody>
            <% if (recentEnrollments.length === 0) { %>
              <tr>
                <td colspan="4" class="px-6 py-8 text-center text-gray-400 text-sm">No recent activity yet</td>
              </tr>
            <% } else { %>
              <% recentEnrollments.forEach(enrollment => { %>
                <tr class="border-b border-gray-50 hover:bg-gray-50">
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                      <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 text-xs font-bold">
                        <%= enrollment.student?.name?.charAt(0) %>
                      </div>
                      <span class="text-sm font-medium text-gray-800"><%= enrollment.student?.name %></span>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-600"><%= enrollment.course?.course_name %></td>
                  <td class="px-6 py-4">
                    <span class="px-2 py-1 bg-green-50 text-green-600 text-xs rounded-full font-medium">
                      <%= enrollment.status %>
                    </span>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-400">
                    <%= new Date(enrollment.enrolled_at).toLocaleDateString() %>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

    </div>
  </div>

  <!-- Charts JS -->
  <script>
    // Enrollment Line Chart
    new Chart(document.getElementById('enrollmentChart'), {
      type: 'line',
      data: {
        labels: ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN'],
        datasets: [{
          data: [30, 45, 38, 60, 72,  totalEnrollments ],
          borderColor: '#2563EB',
          backgroundColor: 'rgba(37,99,235,0.08)',
          borderWidth: 2,
          fill: true,
          tension: 0.4,
          pointRadius: 0,
        }]
      },
      options: {
        plugins: { legend: { display: false } },
        scales: {
          x: { grid: { display: false } },
          y: { grid: { color: '#f1f5f9' }, beginAtZero: true }
        }
      }
    });

    // Attendance Bar Chart
    new Chart(document.getElementById('attendanceChart'), {
      type: 'bar',
      data: {
        labels: ['MON', 'TUE', 'WED', 'THU', 'FRI'],
        datasets: [{
          data: [88, 92, 95, 90,] [attendanceRate || 85],
          backgroundColor: (ctx) =>
            ctx.dataIndex === 4 ? '#2563EB' : '#BFDBFE',
          borderRadius: 6,
        }]
      },
      options: {
        plugins: { legend: { display: false } },
        scales: {
          x: { grid: { display: false } },
          y: { grid: { color: '#f1f5f9' }, beginAtZero: true, max: 100 }
        }
      }
    });
  </script>

</body>
</html>