<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
  <%- include('../partials/sidebar', { currentPage, user }) %>

  <div class="ml-56 min-h-screen">
    <!-- Top Bar -->
    <div class="bg-white border-b border-gray-200 px-8 py-4 flex items-center justify-between">
      <h1 class="text-xl font-bold text-gray-800">Student Management</h1>
      <a href="/api/students/add"
        class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition">
        + Add Student
      </a>
    </div>

    <div class="p-8">
      <!-- Search + Filter -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6 flex items-center gap-4">
        <form method="GET" action="/api/students" class="flex gap-3 flex-1">
          <input type="text" name="search" value="<%= search %>"
            placeholder="Search by name, email or department..."
            class="flex-1 border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"/>
          <button type="submit"
            class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium">Search</button>
          <% if (search) { %>
            <a href="/api/students" class="border border-gray-200 px-4 py-2 rounded-lg text-sm text-gray-600">Clear</a>
          <% } %>
        </form>
      </div>

      <!-- Table -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100">
        <table class="w-full">
          <thead>
            <tr class="text-xs text-gray-400 uppercase border-b border-gray-100">
              <th class="px-6 py-4 text-left">ID</th>
              <th class="px-6 py-4 text-left">Student</th>
              <th class="px-6 py-4 text-left">Email</th>
              <th class="px-6 py-4 text-left">Department</th>
              <th class="px-6 py-4 text-left">Age</th>
              <th class="px-6 py-4 text-left">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (students.length === 0) { %>
              <tr>
                <td colspan="6" class="px-6 py-12 text-center text-gray-400">
                  No students found.
                  <a href="/api/students/add" class="text-blue-600 hover:underline ml-1">Add one?</a>
                </td>
              </tr>
            <% } else { %>
              <% students.forEach(student => { %>
                <tr class="border-b border-gray-50 hover:bg-gray-50 transition">
                  <td class="px-6 py-4 text-sm text-blue-600 font-mono">#STU<%= String(student.id).padStart(3,'0') %></td>
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                      <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 text-xs font-bold">
                        <%= student.name.charAt(0).toUpperCase() %>
                      </div>
                      <div>
                        <div class="text-sm font-semibold text-gray-800"><%= student.name %></div>
                        <div class="text-xs text-gray-400"><%= student.city ?? '' %></div>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-600"><%= student.email %></td>
                  <td class="px-6 py-4 text-sm text-gray-600"><%= student.department %></td>
                  <td class="px-6 py-4 text-sm text-gray-600"><%= student.age %></td>
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                      <a href="/api/students/<%= student.id %>"
                        class="text-blue-600 hover:text-blue-700 text-xs font-medium">View</a>
                      <a href="/api/students/<%= student.id %>/edit"
                        class="text-gray-500 hover:text-gray-700 text-xs font-medium">Edit</a>
                      <form method="POST" action="/api/students/<%= student.id %>/delete"
                        onsubmit="return confirm('Delete this student?')">
                        <button type="submit" class="text-red-400 hover:text-red-600 text-xs font-medium">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>

        <!-- Pagination -->
        <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-between">
          <span class="text-sm text-gray-400">
            Showing <%= (page-1)*limit+1 %> to <%= Math.min(page*limit, total) %> of <%= total %> students
          </span>
          <div class="flex gap-2">
            <% for(let i = 1; i <= totalPages; i++) { %>
              <a href="/api/students?page=<%= i %><%= search ? '&search='+search : '' %>"
                class="w-8 h-8 flex items-center justify-center rounded-lg text-sm
                  <%= i === page ? 'bg-blue-600 text-white' : 'border border-gray-200 text-gray-600 hover:bg-gray-50' %>">
                <%= i %>
              </a>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>