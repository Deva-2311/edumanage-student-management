<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
  <%- include('../partials/sidebar', { currentPage, user }) %>

  <div class="ml-56 min-h-screen">
    <div class="bg-white border-b border-gray-200 px-8 py-4 flex items-center justify-between">
      <h1 class="text-xl font-bold text-gray-800">Student Enrollment</h1>
      <button onclick="document.getElementById('enrollModal').classList.remove('hidden')"
        class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition">
        + Enroll Student
      </button>
    </div>

    <div class="p-8">

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="bg-red-50 text-red-600 px-4 py-3 rounded-lg mb-6 text-sm"><%= error %></div>
      <% } %>

      <!-- Search -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6">
        <form method="GET" action="/api/enrollment" class="flex gap-3">
          <input type="text" name="search" value="<%= search %>"
            placeholder="Search by student name or course title..."
            class="flex-1 border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"/>
          <button type="submit"
            class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium">Search</button>
          <% if (search) { %>
            <a href="/api/enrollment" class="border border-gray-200 px-4 py-2 rounded-lg text-sm text-gray-600">Clear</a>
          <% } %>
        </form>
      </div>

      <!-- Table -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100">
        <table class="w-full">
          <thead>
            <tr class="text-xs text-gray-400 uppercase border-b border-gray-100">
              <th class="px-6 py-4 text-left">Enrollment ID</th>
              <th class="px-6 py-4 text-left">Student Name</th>
              <th class="px-6 py-4 text-left">Course Name</th>
              <th class="px-6 py-4 text-left">Enrollment Date</th>
              <th class="px-6 py-4 text-left">Status</th>
              <th class="px-6 py-4 text-left">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (enrollments.length === 0) { %>
              <tr>
                <td colspan="6" class="px-6 py-12 text-center text-gray-400">
                  No enrollments found.
                  <button onclick="document.getElementById('enrollModal').classList.remove('hidden')"
                    class="text-blue-600 hover:underline ml-1">Enroll a student?</button>
                </td>
              </tr>
            <% } else { %>
              <% enrollments.forEach(enrollment => { %>
                <tr class="border-b border-gray-50 hover:bg-gray-50 transition">
                  <td class="px-6 py-4 text-sm text-blue-600 font-mono">
                    ENR-<%= String(enrollment.id).padStart(4, '0') %>
                  </td>
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                      <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 text-xs font-bold">
                        <%= enrollment.student?.name?.charAt(0).toUpperCase() %>
                      </div>
                      <span class="text-sm font-medium text-gray-800"><%= enrollment.student?.name %></span>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-600"><%= enrollment.course?.course_name %></td>
                  <td class="px-6 py-4 text-sm text-gray-400">
                    <%= new Date(enrollment.enrolled_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                  </td>
                  <td class="px-6 py-4">
                    <span class="px-2 py-1 text-xs rounded-full font-medium
                      <%= enrollment.status === 'active' ? 'bg-green-50 text-green-600' :
                          enrollment.status === 'completed' ? 'bg-blue-50 text-blue-600' :
                          'bg-red-50 text-red-400' %>">
                      <%= enrollment.status.charAt(0).toUpperCase() + enrollment.status.slice(1) %>
                    </span>
                  </td>
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-2">
                      <!-- Status update -->
                      <form method="POST" action="/api/enrollment/<%= enrollment.id %>/status">
                        <select name="status" onchange="this.form.submit()"
                          class="text-xs border border-gray-200 rounded px-2 py-1 text-gray-600 focus:outline-none">
                          <option value="active" <%= enrollment.status === 'active' ? 'selected' : '' %>>Active</option>
                          <option value="completed" <%= enrollment.status === 'completed' ? 'selected' : '' %>>Completed</option>
                          <option value="dropped" <%= enrollment.status === 'dropped' ? 'selected' : '' %>>Dropped</option>
                        </select>
                      </form>
                      <form method="POST" action="/api/enrollment/<%= enrollment.id %>/delete"
                        onsubmit="return confirm('Remove this enrollment?')">
                        <button type="submit" class="text-red-400 hover:text-red-600 text-xs font-medium">Remove</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>

        <!-- Pagination -->
        <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-between">
          <span class="text-sm text-gray-400">
            Showing <%= Math.min((page-1)*limit+1, total) %> to <%= Math.min(page*limit, total) %> of <%= total %> enrollments
          </span>
          <div class="flex gap-2">
            <% for(let i = 1; i <= totalPages; i++) { %>
              <a href="/api/enrollment?page=<%= i %>"
                class="w-8 h-8 flex items-center justify-center rounded-lg text-sm
                  <%= i === page ? 'bg-blue-600 text-white' : 'border border-gray-200 text-gray-600 hover:bg-gray-50' %>">
                <%= i %>
              </a>
            <% } %>
          </div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-4 gap-4 p-6 border-t border-gray-100">
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-xs text-gray-400 mb-1">TOTAL ACTIVE</div>
            <div class="text-2xl font-bold text-gray-800"><%= active %></div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-xs text-gray-400 mb-1">NEW ENROLLEES</div>
            <div class="text-2xl font-bold text-gray-800"><%= total %></div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-xs text-gray-400 mb-1">COMPLETED</div>
            <div class="text-2xl font-bold text-gray-800"><%= completed %></div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4">
            <div class="text-xs text-gray-400 mb-1">DROPPED</div>
            <div class="text-2xl font-bold text-gray-800"><%= dropped %></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Enroll Modal -->
  <div id="enrollModal" class="hidden fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center z-50">
    <div class="bg-white rounded-2xl shadow-xl p-8 w-full max-w-md">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-bold text-gray-800">Enroll Student</h2>
        <button onclick="document.getElementById('enrollModal').classList.add('hidden')"
          class="text-gray-400 hover:text-gray-600 text-xl">✕</button>
      </div>
      <form method="POST" action="/api/enrollment">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">Select Student</label>
          <select name="student_id" required
            class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="">Choose a student...</option>
            <% students.forEach(student => { %>
              <option value="<%= student.id %>"><%= student.name %> — <%= student.department %></option>
            <% }) %>
          </select>
        </div>
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 mb-1">Select Course</label>
          <select name="course_id" required
            class="w-full border border-gray-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="">Choose a course...</option>
            <% courses.forEach(course => { %>
              <option value="<%= course.id %>"><%= course.course_code %> — <%= course.course_name %></option>
            <% }) %>
          </select>
        </div>
        <div class="flex gap-3">
          <button type="submit"
            class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 rounded-lg transition text-sm">
            Enroll Student
          </button>
          <button type="button"
            onclick="document.getElementById('enrollModal').classList.add('hidden')"
            class="flex-1 border border-gray-200 text-gray-600 font-medium py-2.5 rounded-lg text-sm hover:bg-gray-50">
            Cancel
          </button>
        </div>
      </form>
    </div>
  </div>

</body>
</html>
