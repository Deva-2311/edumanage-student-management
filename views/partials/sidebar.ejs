<div class="fixed left-0 top-0 h-full w-56 bg-white border-r border-gray-200 flex flex-col z-10">
  <!-- Logo -->
  <div class="px-6 py-5 border-b border-gray-100">
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center text-white text-sm">🎓</div>
      <div>
        <div class="font-bold text-gray-800 text-sm">EduManage</div>
        <div class="text-xs text-gray-400 capitalize"><%= user?.role ?? 'Portal' %></div>
      </div>
    </div>
  </div>

  <!-- Nav -->
  <nav class="flex-1 px-3 py-4 space-y-1">
    <a href="/api/dashboard" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium <%= currentPage === 'dashboard' ? 'bg-blue-50 text-blue-600' : 'text-gray-600 hover:bg-gray-50' %>">
      <span>📊</span> Dashboard
    </a>
    <a href="/api/students" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium <%= currentPage === 'students' ? 'bg-blue-50 text-blue-600' : 'text-gray-600 hover:bg-gray-50' %>">
      <span>👤</span> Students
    </a>
    <a href="/api/courses" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium <%= currentPage === 'courses' ? 'bg-blue-50 text-blue-600' : 'text-gray-600 hover:bg-gray-50' %>">
      <span>📚</span> Courses
    </a>
    <a href="/api/attendance" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium <%= currentPage === 'attendance' ? 'bg-blue-50 text-blue-600' : 'text-gray-600 hover:bg-gray-50' %>">
      <span>✅</span> Attendance
    </a>
    <a href="/api/enrollment" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium <%= currentPage === 'enrollment' ? 'bg-blue-50 text-blue-600' : 'text-gray-600 hover:bg-gray-50' %>">
      <span>🔗</span> Enrollment
    </a>
    <a href="/api/marks" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium <%= currentPage === 'marks' ? 'bg-blue-50 text-blue-600' : 'text-gray-600 hover:bg-gray-50' %>">
      <span>📝</span> Marks
    </a>
    <% if (user?.role === 'admin') { %>
    <a href="/api/logs" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium <%= currentPage === 'logs' ? 'bg-blue-50 text-blue-600' : 'text-gray-600 hover:bg-gray-50' %>">
      <span>🕓</span> Logs
    </a>
    <a href="/api/admin/users" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium <%= currentPage === 'users' ? 'bg-blue-50 text-blue-600' : 'text-gray-600 hover:bg-gray-50' %>">
      <span>👥</span> Users
    </a>
    <% } %>
    <a href="/api/settings/profile" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium <%= currentPage === 'settings' ? 'bg-blue-50 text-blue-600' : 'text-gray-600 hover:bg-gray-50' %>">
      <span>⚙️</span> Settings
    </a>
  </nav>

  <!-- User + Logout -->
  <div class="px-4 py-4 border-t border-gray-100">
    <div class="text-xs font-semibold text-gray-800"><%= user?.name ?? 'User' %></div>
    <div class="text-xs text-gray-400 mb-2 capitalize"><%= user?.role ?? '' %></div>
    <a href="/api/logout" class="flex items-center gap-2 text-xs text-red-500 hover:text-red-600">
      <span>→</span> Logout
    </a>
  </div>
</div>