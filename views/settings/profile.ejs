<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
  <%- include('../partials/sidebar', { currentPage, user }) %>

  <div class="ml-56 min-h-screen">
    <!-- Header -->
    <div class="bg-white border-b border-gray-200 px-8 py-4">
      <h1 class="text-xl font-bold text-gray-800">My Profile</h1>
      <p class="text-xs text-gray-400 mt-0.5">Manage your account details and password</p>
    </div>

    <div class="p-8">
      <!-- Tab Nav -->
      <div class="flex gap-1 mb-6 bg-white border border-gray-100 rounded-xl p-1 w-fit shadow-sm">
        <a href="/api/settings/system" class="px-5 py-2 rounded-lg text-sm font-medium text-gray-500 hover:bg-gray-50 transition">System</a>
        <span class="px-5 py-2 rounded-lg text-sm font-medium bg-blue-600 text-white">Profile</span>
      </div>

      <!-- Alert -->
      <% if (success) { %>
        <div class="mb-6 bg-green-50 border border-green-200 text-green-700 rounded-xl px-4 py-3 text-sm flex items-center gap-2">
          <span>✓</span> <%= success %>
        </div>
      <% } %>
      <% if (error) { %>
        <div class="mb-6 bg-red-50 border border-red-200 text-red-600 rounded-xl px-4 py-3 text-sm flex items-center gap-2">
          <span>✗</span> <%= error %>
        </div>
      <% } %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Profile Info -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 bg-blue-600 rounded-xl flex items-center justify-center text-white text-2xl font-bold">
              <%= profile.name.charAt(0).toUpperCase() %>
            </div>
            <div>
              <div class="font-bold text-gray-800 text-lg"><%= profile.name %></div>
              <div class="text-sm text-gray-400"><%= profile.email %></div>
              <span class="px-2 py-0.5 mt-1 inline-block text-xs rounded-full font-medium bg-blue-50 text-blue-600 capitalize"><%= profile.role %></span>
            </div>
          </div>

          <h3 class="text-sm font-semibold text-gray-700 mb-4">Update Display Name</h3>
          <form method="POST" action="/api/settings/profile" class="space-y-4">
            <div>
              <label class="text-xs text-gray-500 font-medium block mb-1">Full Name</label>
              <input type="text" name="name" value="<%= profile.name %>" required
                class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"/>
            </div>
            <div>
              <label class="text-xs text-gray-500 font-medium block mb-1">Email (read-only)</label>
              <input type="email" value="<%= profile.email %>" disabled
                class="w-full border border-gray-100 rounded-lg px-4 py-2.5 text-sm bg-gray-50 text-gray-400 cursor-not-allowed"/>
            </div>
            <button type="submit"
              class="w-full bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold py-2.5 rounded-lg transition">
              Save Changes
            </button>
          </form>
        </div>

        <!-- Change Password -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h3 class="text-sm font-semibold text-gray-700 mb-1">Change Password</h3>
          <p class="text-xs text-gray-400 mb-5">Your new password must be secure and memorable.</p>
          <form method="POST" action="/api/settings/password" class="space-y-4">
            <div>
              <label class="text-xs text-gray-500 font-medium block mb-1">Current Password</label>
              <input type="password" name="current_password" required autocomplete="current-password"
                class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"/>
            </div>
            <div>
              <label class="text-xs text-gray-500 font-medium block mb-1">New Password</label>
              <input type="password" name="new_password" required minlength="6" autocomplete="new-password"
                class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"/>
            </div>
            <div>
              <label class="text-xs text-gray-500 font-medium block mb-1">Confirm New Password</label>
              <input type="password" name="confirm_password" required minlength="6" autocomplete="new-password"
                oninput="this.setCustomValidity(this.value !== document.querySelector('[name=new_password]').value ? 'Passwords do not match' : '')"
                class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"/>
            </div>
            <button type="submit"
              class="w-full bg-gray-800 hover:bg-gray-900 text-white text-sm font-semibold py-2.5 rounded-lg transition">
              Change Password
            </button>
          </form>

          <div class="mt-6 pt-4 border-t border-gray-100">
            <p class="text-xs text-gray-400">
              Password requirements: Minimum 6 characters.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
