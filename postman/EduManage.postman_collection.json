{
  "info": {
    "_postman_id": "edumanage-v1",
    "name": "EduManage API",
    "description": "Complete API collection for EduManage Student Management System\nBase URL: http://localhost:3000\n\nAuth: Login first (POST /auth/login) to get JWT cookie, then all subsequent requests use that cookie automatically in the browser.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/login",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Portal Page",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/",
            "description": "Landing page — select Admin or Teacher portal"
          }
        },
        {
          "name": "Admin Login Page",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/login/admin",
            "description": "Renders admin login form"
          }
        },
        {
          "name": "Teacher Login Page",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/login/teacher",
            "description": "Renders teacher login form"
          }
        },
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "email",
                  "value": "admin@edumanage.edu"
                },
                {
                  "key": "password",
                  "value": "admin123"
                },
                {
                  "key": "role",
                  "value": "admin"
                }
              ]
            },
            "description": "Login with admin credentials. Sets JWT cookie on success and redirects to /dashboard."
          }
        },
        {
          "name": "Register New User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Teacher\",\n  \"email\": \"john@edumanage.edu\",\n  \"password\": \"teacher123\",\n  \"role\": \"teacher\"\n}"
            },
            "description": "Register a new user (admin or teacher). Returns success message."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/logout",
            "description": "Clears JWT cookie and redirects to portal"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard",
            "description": "Main dashboard with stats: total students, courses, enrollments, attendance rate, recent logs, recent enrollments."
          }
        }
      ]
    },
