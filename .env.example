# ─────────────────────────────────────────────────────────────
# EduManage — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_database_password
DB_NAME=edumanage

# ── JWT Authentication ─────────────────────────────────────────
# Must be at least 32 characters for security
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRES=1d

# ── Server ────────────────────────────────────────────────────
PORT=3000

# ── Webhooks (optional) ───────────────────────────────────────
# Triggered automatically when a new student is created
# Leave empty to disable webhook
WEBHOOK_URL=
